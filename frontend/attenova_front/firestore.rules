rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId 
          && data.email is string && data.email.size() <= 256;
      }

      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()); 
      allow update: if isOwner(userId) && isValidUser(incoming());
    }

    // Session Rules
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Monthly Stats
    match /users/{userId}/stats/monthly {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId); // Simplified for aggregation logic in client for demo
    }
  }
}
